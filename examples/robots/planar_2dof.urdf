<?xml version="1.0" encoding="utf-8"?>
<!-- Planar 2-DOF robot arm lying on the XY-plane.
     Both revolute joints rotate around the Z-axis, so motion is constrained
     to the XY-plane. Based on double_pendulum.urdf but reoriented. -->
<!-- SPDX-License-Identifier: Apache-2.0 -->
<robot name="planar_2dof">
  <link name="base_link">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <mass value="0.1" />
      <inertia ixx="1" ixy="0" ixz="0" iyy="1" iyz="0" izz="1" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <box size="0.05 0.05 0.05"/>
      </geometry>
      <material name="red">
        <color rgba="1 0 0 1" />
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <box size="0.05 0.05 0.05"/>
      </geometry>
    </collision>
  </link>

  <link name="link1">
    <inertial>
      <origin xyz="0.1 0 0" rpy="0 0 0" />
      <mass value="0.2" />
      <inertia ixx="0.000020833" ixy="0" ixz="0" iyy="0.000177083" iyz="0" izz="0.000177083" />
    </inertial>
    <visual>
      <origin xyz="0.1 0 0" rpy="0 0 0" />
      <geometry>
        <box size="0.2 0.025 0.025"/>
      </geometry>
      <material name="green">
        <color rgba="0 1 0 1" />
      </material>
    </visual>
    <collision>
      <origin xyz="0.1 0 0" rpy="0 0 0" />
      <geometry>
        <box size="0.2 0.025 0.025"/>
      </geometry>
    </collision>
  </link>

  <joint name="joint1" type="revolute">
    <origin xyz="0.025 0 0" rpy="0 0 0" />
    <parent link="base_link" />
    <child link="link1" />
    <axis xyz="0 0 1" />
    <limit lower="-3.14159" upper="3.14159" effort="10" velocity="2" />
    <dynamics damping="0.05" />
  </joint>

  <link name="link2">
    <inertial>
      <origin xyz="0.1 0 0" rpy="0 0 0" />
      <mass value="0.3" />
      <inertia ixx="0.002" ixy="0" ixz="0" iyy="0.001015625" iyz="0" izz="0.001015625" />
    </inertial>
    <visual>
      <origin xyz="0.1 0 0" rpy="0 0 0" />
      <geometry>
        <box size="0.2 0.025 0.025"/>
      </geometry>
      <material name="blue">
        <color rgba="0 0 1 1" />
      </material>
    </visual>
    <collision>
      <origin xyz="0.1 0 0" rpy="0 0 0" />
      <geometry>
        <box size="0.2 0.025 0.025"/>
      </geometry>
    </collision>
  </link>

  <joint name="joint2" type="revolute">
    <origin xyz="0.2 0 0" rpy="0 0 0" />
    <parent link="link1" />
    <child link="link2" />
    <axis xyz="0 0 1" />
    <limit lower="-3.14159" upper="3.14159" effort="10" velocity="2" />
    <dynamics damping="0.05" />
  </joint>

  <link name="end_effector">
    <inertial>
      <mass value="0.0"/>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <inertia ixx="0.0" ixy="0.0" ixz="0.0" iyy="0.0" iyz="0.0" izz="0.0"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <sphere radius="0.02"/>
      </geometry>
      <material name="yellow">
        <color rgba="1 1 0 1" />
      </material>
    </visual>
  </link>

  <joint name="end_effector_joint" type="fixed">
    <origin xyz="0.2 0 0" rpy="0 0 0" />
    <parent link="link2" />
    <child link="end_effector" />
  </joint>
</robot>
